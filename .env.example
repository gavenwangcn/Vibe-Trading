# =============================================================================
# Vibe-Trading — 统一环境变量（Docker Compose 与本地运行）
# =============================================================================
# 使用方式：
#   1. 复制本文件：cp .env.example .env
#   2. 将 agent/.env.example 中的 LLM、数据源等配置**合并**进 .env（或先 cp agent/.env .env 再追加下方「微信桥」变量）
#   3. Docker：在 Vibe-Trading 目录执行：docker compose up -d
#
# 说明：Compose 统一从本目录的 .env 注入环境变量（不再读取 agent/.env）。仅本地开发仍可使用 agent/.env，由 vibe-trading CLI 按原逻辑加载。
# =============================================================================

# -----------------------------------------------------------------------------
# 微信桥 wechat-bridge（与 vibe-trading 同栈：docker compose up -d）
# -----------------------------------------------------------------------------
# 数据隔离（多微信 / 多容器）：同一套镜像与 compose，仅改下列三项即可；宿主机目录为
#   {WECHAT_DATA_ROOT}/{WECHAT_INSTANCE_NAME}/
# 例如 WECHAT_DATA_ROOT=. 且 WECHAT_INSTANCE_NAME=a → 项目根下 ./a/ 存该实例微信凭证与 state。
# WECHAT_CONTAINER_NAME：可选。不填则 Docker Compose 按项目名自动生成唯一容器名；多实例并行时勿重复。
# 若需短名（如容器名=a），填写 WECHAT_CONTAINER_NAME=a，并与 WECHAT_INSTANCE_NAME=a 对齐。
WECHAT_DATA_ROOT=./wechat-instances
WECHAT_INSTANCE_NAME=default
# WECHAT_CONTAINER_NAME=
#
# 容器内由 docker-compose 强制覆盖以下路径，一般无需改：
#   VIBE_TRADING_BASE_URL=http://vibe-trading:8899
#   WECHAT_BRIDGE_STATE_FILE=/data/state.json
#   WECHATBOT_STORAGE_DIR=/data/wechatbot
#
# 在宿主机直接运行 npm start（非 Docker）时，可设为：
VIBE_TRADING_BASE_URL=http://156.254.6.224:8899
#WECHAT_BRIDGE_STATE_FILE=
#WECHATBOT_STORAGE_DIR=

VIBE_TURN_TIMEOUT_MS=600000
WECHAT_LOG_LEVEL=info

# 流式输出（text_delta → 分段微信消息）与工具进度
WECHAT_STREAM_ENABLED=1
WECHAT_STREAM_INTERVAL_MS=1200
WECHAT_STREAM_MIN_CHARS=180
WECHAT_MSG_MIN_GAP_MS=450
WECHAT_TOOL_NOTIFY=1
# each | merge | result_only
WECHAT_TOOL_DISPLAY=merge
WECHAT_TOOL_BATCH_MS=550

# -----------------------------------------------------------------------------
# 以下为占位：请从 agent/.env.example 复制完整配置（LLM、TUSHARE 等）
# -----------------------------------------------------------------------------
# LANGCHAIN_PROVIDER=
# LANGCHAIN_MODEL_NAME=
# ...
