# 微信桥 wechat-bridge 专用（复制为 wechat-bridge/.env；勿与 agent/.env 混用）
# Docker：docker compose 会只把本文件注入 wechat-bridge 容器。

# 数据隔离（多实例）：宿主机目录 {WECHAT_DATA_ROOT}/{WECHAT_INSTANCE_NAME}/
WECHAT_DATA_ROOT=./wechat-instances
WECHAT_INSTANCE_NAME=default
# WECHAT_CONTAINER_NAME=

# 本地 npm start（非 Docker）时指向宿主机 API；容器内由 compose 覆盖为 http://vibe-trading:8899
VIBE_TRADING_BASE_URL=http://156.254.6.224:8899

# 访问 ilinkai.weixin.qq.com（拉二维码等）；默认已在 SDK 内放宽，仍超时再加，例如 90000
# WECHAT_ILINK_HTTP_TIMEOUT_MS=60000

VIBE_TURN_TIMEOUT_MS=600000
WECHAT_LOG_LEVEL=info

WECHAT_STREAM_ENABLED=1
# 以下为旧版「分段刷微信」参数，当前已改为回合结束单次发送，可忽略或删除
# WECHAT_STREAM_INTERVAL_MS=1200
# WECHAT_STREAM_MIN_CHARS=180
WECHAT_MSG_MIN_GAP_MS=450
WECHAT_TOOL_NOTIFY=1
WECHAT_TOOL_DISPLAY=merge
WECHAT_TOOL_BATCH_MS=550

# 同步到 Vibe 会话标题（网页端列表）；默认 Trading Agent
# WECHAT_SESSION_TITLE_PREFIX=Trading Agent

# /help、/介绍 中的能力说明（单行；如需换行可用 \n）。微信资料页「功能介绍」须在公众平台后台单独改
# WECHAT_CAPABILITY_INTRO=【能力】AI 自动化盯盘、策略回测与交易辅助……
